options gen2
require daslib/daspkg

[export]
def package() {
    package_name("das-cards")
    package_author("borisbat")
    package_description("Vector playing card rendering — SVG-based triangle mesh cards for OpenGL")
    package_license("LGPL-2.1")
    package_tag("graphics")
    package_tag("games")
    package_tag("cards")
    package_source("github.com/borisbat/dasCards")
}

[export]
def resolve(sdk_version, version : string) {
    if (empty(version) || version == "latest") {
        download_branch("main")
    } else {
        download_tag("v{version}")
    }
}

[export]
def release() {
    // Runtime assets loaded by dasCards (e.g. card_mesh.das opens
    // `{dir_name(get_module_file_name("card_mesh"))}/svg-cards.svg`).
    // Shipped at <bundle>/modules/das-cards/cards/<file> so the recipient
    // exe finds them at the same relative layout.
    release_include("cards/svg-cards.svg")
    release_include("cards/DejaVuSerif.ttf")
}
